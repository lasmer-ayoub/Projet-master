{
  "info": {
    "name": "masterproject API",
    "description": "Collection complete pour tester le backend de gestion de projets (To Do List + tickets).\n\nORDRE CONSEILLE :\n1. Auth > Connexion (admin)  -> enregistre le token automatiquement\n2. (option) Auth > Inscription -> cree un membre a inviter ensuite\n3. Projets > Creer un projet -> enregistre projectId automatiquement\n4. Projets > Ajouter un membre\n5. Tickets > Creer un ticket -> enregistre ticketId automatiquement\n6. Tickets > Changer le statut / Modifier / Historique\n7. Commentaires > Ajouter / Lister\n8. Projets > Statistiques\n\nLes variables {{token}}, {{projectId}} et {{ticketId}} se remplissent toutes seules grace aux petits scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "projectId", "value": "", "type": "string" },
    { "key": "ticketId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Connexion (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Enregistre automatiquement le token renvoye dans la variable {{token}}",
                  "var data = pm.response.json();",
                  "if (data && data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "    console.log('Token enregistre.');",
                  "}",
                  "pm.test('Connexion reussie (200)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@masterproject.com\",\n  \"motDePasse\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "login" ] },
            "description": "Connexion avec le compte admin cree automatiquement au demarrage. Le token est enregistre dans {{token}}."
          }
        },
        {
          "name": "Inscription (nouveau membre)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Membre Test\",\n  \"email\": \"membre@test.com\",\n  \"motDePasse\": \"membre123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "api", "auth", "register" ] },
            "description": "Cree un nouvel utilisateur avec le role systeme USER. Sert ensuite a etre invite dans un projet."
          }
        }
      ]
    },
    {
      "name": "2. Utilisateurs",
      "item": [
        {
          "name": "Mon profil",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": [ "{{baseUrl}}" ], "path": [ "api", "users", "me" ] },
            "description": "Renvoie les informations de l'utilisateur actuellement connecte (celui du token)."
          }
        },
        {
          "name": "Lister tous les utilisateurs (ADMIN)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/users", "host": [ "{{baseUrl}}" ], "path": [ "api", "users" ] },
            "description": "Reserve a l'ADMIN. Renvoie la liste de tous les utilisateurs. Si tu es connecte en simple USER, tu auras une erreur 403 (acces refuse) : c'est normal."
          }
        }
      ]
    },
    {
      "name": "3. Projets",
      "item": [
        {
          "name": "Creer un projet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Enregistre l'id du projet cree dans la variable {{projectId}}",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "    pm.collectionVariables.set('projectId', data.id);",
                  "    console.log('projectId enregistre : ' + data.id);",
                  "}",
                  "pm.test('Projet cree (200)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Projet de demonstration\",\n  \"description\": \"Projet cree pour la soutenance\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/projects", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects" ] },
            "description": "Cree un projet. L'utilisateur connecte en devient automatiquement le RESPONSABLE. L'id est enregistre dans {{projectId}}."
          }
        },
        {
          "name": "Mes projets",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/projects", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects" ] },
            "description": "Liste les projets dont l'utilisateur connecte est membre (ou responsable)."
          }
        },
        {
          "name": "Detail d'un projet",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects", "{{projectId}}" ] },
            "description": "Renvoie le detail d'un projet. Utilise la variable {{projectId}} enregistree a la creation."
          }
        },
        {
          "name": "Ajouter un membre",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"membre@test.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/members", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects", "{{projectId}}", "members" ] },
            "description": "Ajoute un utilisateur existant comme MEMBRE du projet. Reserve au RESPONSABLE du projet. (Cree d'abord l'utilisateur via Auth > Inscription.)"
          }
        },
        {
          "name": "Lister les membres",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/members", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects", "{{projectId}}", "members" ] },
            "description": "Liste les membres du projet et leur role projet (RESPONSABLE / MEMBRE)."
          }
        },
        {
          "name": "Statistiques du projet",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/stats", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects", "{{projectId}}", "stats" ] },
            "description": "Renvoie le tableau de bord : nombre total de tickets, repartition par statut, et pourcentage d'avancement."
          }
        }
      ]
    },
    {
      "name": "4. Tickets",
      "item": [
        {
          "name": "Creer un ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Enregistre l'id du ticket cree dans la variable {{ticketId}}",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "    pm.collectionVariables.set('ticketId', data.id);",
                  "    console.log('ticketId enregistre : ' + data.id);",
                  "}",
                  "pm.test('Ticket cree (200)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Premier ticket\",\n  \"description\": \"Description du ticket de test\",\n  \"type\": \"TACHE\",\n  \"priorite\": \"MOYENNE\",\n  \"responsableEmail\": \"membre@test.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/tickets", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects", "{{projectId}}", "tickets" ] },
            "description": "Cree un ticket dans le projet. Reserve au RESPONSABLE.\n\nValeurs possibles :\n- type : TACHE, BUG, AMELIORATION, DEMANDE, URGENCE\n- priorite : FAIBLE, MOYENNE, HAUTE, CRITIQUE\n\nresponsableEmail peut etre laisse vide (\"\") si le ticket n'est affecte a personne."
          }
        },
        {
          "name": "Lister les tickets d'un projet",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/tickets", "host": [ "{{baseUrl}}" ], "path": [ "api", "projects", "{{projectId}}", "tickets" ] },
            "description": "Liste tous les tickets du projet."
          }
        },
        {
          "name": "Lister les tickets (avec filtres)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}/tickets?statut=A_FAIRE&priorite=MOYENNE",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "projects", "{{projectId}}", "tickets" ],
              "query": [
                { "key": "statut", "value": "A_FAIRE", "description": "Optionnel : A_FAIRE, EN_COURS, EN_ATTENTE, BLOQUE, A_VALIDER, ANNULE, TERMINE" },
                { "key": "priorite", "value": "MOYENNE", "description": "Optionnel : FAIBLE, MOYENNE, HAUTE, CRITIQUE" },
                { "key": "responsable", "value": "", "description": "Optionnel : email du responsable", "disabled": true }
              ]
            },
            "description": "Liste les tickets avec des filtres optionnels. Tu peux supprimer ou desactiver les filtres que tu ne veux pas utiliser."
          }
        },
        {
          "name": "Detail d'un ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "tickets", "{{ticketId}}" ] },
            "description": "Renvoie le detail d'un ticket."
          }
        },
        {
          "name": "Modifier un ticket",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Premier ticket (modifie)\",\n  \"description\": \"Description mise a jour\",\n  \"type\": \"BUG\",\n  \"priorite\": \"HAUTE\",\n  \"statut\": \"EN_COURS\",\n  \"responsableEmail\": \"membre@test.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "tickets", "{{ticketId}}" ] },
            "description": "Modifie un ticket. Chaque changement est enregistre dans l'historique."
          }
        },
        {
          "name": "Changer le statut (Kanban)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tickets/{{ticketId}}/statut?valeur=EN_COURS",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "tickets", "{{ticketId}}", "statut" ],
              "query": [
                { "key": "valeur", "value": "EN_COURS", "description": "A_FAIRE, EN_COURS, EN_ATTENTE, BLOQUE, A_VALIDER, ANNULE, TERMINE" }
              ]
            },
            "description": "Change uniquement le statut d'un ticket (deplacement dans le Kanban). Le changement est historise."
          }
        },
        {
          "name": "Historique d'un ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}/historique", "host": [ "{{baseUrl}}" ], "path": [ "api", "tickets", "{{ticketId}}", "historique" ] },
            "description": "Liste l'historique des modifications du ticket (champ modifie, ancienne valeur, nouvelle valeur, date, auteur)."
          }
        },
        {
          "name": "Supprimer un ticket",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}", "host": [ "{{baseUrl}}" ], "path": [ "api", "tickets", "{{ticketId}}" ] },
            "description": "Supprime le ticket (ainsi que ses commentaires et son historique). Reserve au RESPONSABLE. A lancer en dernier, sinon les autres requetes ticket ne trouveront plus rien."
          }
        }
      ]
    },
    {
      "name": "5. Commentaires",
      "item": [
        {
          "name": "Ajouter un commentaire",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contenu\": \"Voici un commentaire de test sur le ticket.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}/comments", "host": [ "{{baseUrl}}" ], "path": [ "api", "tickets", "{{ticketId}}", "comments" ] },
            "description": "Ajoute un commentaire sur un ticket. Reserve aux membres du projet."
          }
        },
        {
          "name": "Lister les commentaires",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}/comments", "host": [ "{{baseUrl}}" ], "path": [ "api", "tickets", "{{ticketId}}", "comments" ] },
            "description": "Liste les commentaires d'un ticket."
          }
        }
      ]
    }
  ]
}
